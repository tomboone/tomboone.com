{
  "routes": [
    {
      "route": "/infrastructure/*",
      "statusCode": 404
    },
    {
      "route": "/docker-compose.yml",
      "statusCode": 404
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN"
  },
  "trailingSlash": "always"
}
